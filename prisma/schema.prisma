generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  telegramId String  @unique // User ID or username if ID unknown
  username  String?
  firstName String?
  lastName  String?
  accessHash String? // For users without username (by ID)
  bio       String?
  status    UserStatus @default(NEW)
  tags      Json?    // Stored as JSON array of strings
  facts     Json?    // Stored as JSON object: { occupation: "...", country: "...", ... }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dialogues Dialogue[]
  
  // Source Tracking
  sourceChatId Int?
  sourceChat   ScannedChat? @relation(fields: [sourceChatId], references: [id])
  revenue      Float    @default(0.0)

  // Profile Fields (Networking Assistant)
  city            String?
  activity        String?  // Sphere of activity
  businessCard    String?  // Raw text of business card/bio
  bestClients     String?  // Description of best clients
  requests        String?  // Common requests/tasks
  hobbies         String?
  currentIncome   String?  // Flexible string for range/value
  desiredIncome   String?
  networkingGoal  String?  // Context/Goal
  profileStatus   ProfileStatus @default(EMPTY)

  // Automation flags
  autoReply       Boolean  @default(false) // If true — listener sends GPT replies without operator approval
  notifiedNew     Boolean  @default(false) // Admin already got "new lead" notification
  notifiedLead    Boolean  @default(false) // Admin already got "promoted to LEAD" notification

  // Auto-generated business cards (cached, regenerated on demand)
  briefCard       String?     // 1-2 sentences for partner display
  fullCard        String?     // structured multiline card with all known data
  cardGeneratedAt DateTime?

  // Demographics (auto-derived from firstName for RU names; can be overridden)
  gender          Gender   @default(UNKNOWN)

  // Outreach throttling
  lastBroadcastAt DateTime?    // last time we sent them a Broadcast template
  lastBroadcastTemplateId Int?

  rules        Rule[]
}

enum Gender {
  MALE
  FEMALE
  UNKNOWN
}

model ScannedChat {
  id          Int      @id @default(autoincrement())
  username    String?
  title       String? // Chat title
  link        String? // Original link used
  accessHash  String? // For resolving by ID
  scannedAt   DateTime @default(now())
  lastLeadsCount Int   @default(0)
  
  users       User[]
  leads       ScoutLead[]
  scanHistory ScanHistory[]
}

model ScanHistory {
  id          Int      @id @default(autoincrement())
  scannedChatId Int
  chat        ScannedChat @relation(fields: [scannedChatId], references: [id])
  
  keywords    String?  // Keywords used for this scan
  limit       Int      @default(50)
  leads       Json     // Stored as JSON array of lead objects
  leadsCount  Int      @default(0)
  
  createdAt   DateTime @default(now())
}

model ScoutLead {
  id          Int      @id @default(autoincrement())
  scannedChatId Int
  chat        ScannedChat @relation(fields: [scannedChatId], references: [id], onDelete: Cascade)

  // Optional link to the dialogue that imported this lead
  dialogueId  Int?
  dialogue    Dialogue? @relation(fields: [dialogueId], references: [id], onDelete: SetNull)

  senderUsername String?
  senderId       String?  // Telegram ID
  text           String

  relevance   LeadRelevance @default(UNKNOWN)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum LeadRelevance {
  UNKNOWN
  RELEVANT
  IRRELEVANT
}

model Dialogue {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  status    DialogueStatus @default(ACTIVE)
  stage     DialogueStage  @default(DISCOVERY)
  source    DialogueSource @default(INBOUND)
  outcome   DialogueOutcome @default(IN_PROGRESS)
  botId     String   @default("arthur")  // какой бот ведёт диалог (persona BOT_ID)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages   Message[]
  scoutLeads ScoutLead[]

  @@index([botId])
  @@index([userId, botId])
}

// Запись на созвон с Романом (booking). Бот бронит 30-мин слот 13-17 МСК,
// уведомляет Романа + напоминает утром и за 15 мин.
model Meeting {
  id             Int      @id @default(autoincrement())
  userId         Int
  dialogueId     Int?
  botId          String   @default("arthur")
  scheduledAt    DateTime // UTC, начало слота
  durationMin    Int      @default(30)
  status         String   @default("BOOKED") // BOOKED | REMINDED_MORNING | REMINDED_15 | DONE | CANCELLED
  clientUsername String?
  clientName     String?
  remindedMorning Boolean @default(false)
  reminded15     Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@index([scheduledAt])
  @@index([status])
}

enum DialogueOutcome {
  IN_PROGRESS       // active conversation, not concluded yet
  DROPPED_NO_REPLY  // user never replied to our outreach
  DROPPED_ICED      // user replied once or twice and went silent
  QUALIFIED         // bot reached QUALIFIED user status
  MATCHED           // user got matched with someone
  CUSTOMER          // closed deal / paying
}

model Message {
  id         Int      @id @default(autoincrement())
  dialogueId Int
  dialogue   Dialogue @relation(fields: [dialogueId], references: [id])
  sender     MessageSender
  text       String
  status     MessageStatus @default(SENT)
  feedback   String?       // Operator feedback/correction for this message
  createdAt  DateTime @default(now())
  readAt     DateTime?     // Set when the recipient's Telegram reports having read up to this point (UpdateReadHistoryOutbox)
}

model Template {
  id        Int      @id @default(autoincrement())
  name      String   @unique // e.g., "discovery_intro", "offer_main"
  content   String   // The prompt/message template
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attempts  OutreachAttempt[]
}

// One row per (template, recipient) when a broadcast is sent. Used to compute
// reply / lead / match conversion statistics per scenario.
model OutreachAttempt {
  id            Int       @id @default(autoincrement())
  templateId    Int
  template      Template  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId        Int
  sentAt        DateTime  @default(now())
  mode          String    @default("draft") // 'draft' | 'auto' — how the broadcast was sent

  // outcomes — set as the user progresses
  firstReplyAt    DateTime?
  becameLeadAt    DateTime?
  becameMatchedAt DateTime?
  becameCustomerAt DateTime?

  @@index([templateId, sentAt])
  @@index([userId, sentAt])
}

model KnowledgeItem {
  id        Int      @id @default(autoincrement())
  question  String   // The primary question/intent
  answer    String   // The approved answer
  tags      Json?    // Array of tags/categories
  hits      Int      @default(0) // Usage count
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LearningCandidate {
  id              Int      @id @default(autoincrement())
  originalQuestion String
  operatorAnswer  String
  status          CandidateStatus @default(PENDING) // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
}

enum CandidateStatus {
  PENDING
  APPROVED
  REJECTED
  MERGED
}

enum UserStatus {
  NEW
  CHAT
  LEAD
  QUALIFIED
  REJECTED
  MATCHED
  BLOCKED
  CUSTOMER
}

enum DialogueStatus {
  ACTIVE
  ARCHIVED
}

enum DialogueStage {
  DISCOVERY
  OFFER
  QUALIFICATION
  CLOSED
}

enum DialogueSource {
  INBOUND
  SCOUT
}

enum MessageSender {
  USER
  SIMULATOR
  OPERATOR
}

enum MessageStatus {
  SENT
  DRAFT
  RECEIVED
}

model Rule {
  id        Int      @id @default(autoincrement())
  content   String
  isActive  Boolean  @default(true)
  isGlobal  Boolean  @default(false)
  userId    Int?     // Optional relation to User
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model IgnoreTrigger {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique
  type      String   @default("KEYWORD") // KEYWORD, USERNAME, PHONE
  createdAt DateTime @default(now())
}

// Conversation Brain — accumulated patterns extracted from real dialogues.
// Source: human-in-loop (operator overrides) + auto-analyzer (daily cron).
// Used by listener: top-K active scenarios for the current stage are mixed
// into the system prompt as few-shot guidance.
model LearnedScenario {
  id          Int      @id @default(autoincrement())
  stage       DialogueStage   // when does this pattern apply
  trigger     String          // text-описание ситуации ("user dodges with 'see profile'")
  recommend   String          // what to say (concrete reply or pattern)
  avoid       String?         // what NOT to say
  source      String   @default("manual") // manual | human_override | auto_analyzer
  successScore Float   @default(0)        // 0..1 — how often this leads to engagement
  usageCount   Int     @default(0)
  isActive     Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastUsedAt   DateTime?
  notes        String?         // operator notes
}

enum ProfileStatus {
  EMPTY
  PARTIAL
  COMPLETE
}
